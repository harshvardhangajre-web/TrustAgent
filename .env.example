# Copy to .env.local and fill in values. Restart `npm run dev` after changes.

# Shardeum Mezame
NEXT_PUBLIC_SHARDEUM_RPC=https://api-mezame.shardeum.org
NEXT_PUBLIC_CHAIN_ID=8119

# After `npm run hh:deploy:trust`
NEXT_PUBLIC_TRUST_AGENT_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: legacy ActionLog demo
# NEXT_PUBLIC_ACTION_LOG_ADDRESS=0x0000000000000000000000000000000000000000

# Hardhat deploy (Mezame) — 64 hex chars, with or without 0x (placeholders break compile if not valid hex)
PRIVATE_KEY=

# Same as deployer by default, or set a dedicated oracle wallet
ORACLE_ADDRESS=

# Backend signs executeOutcome — must match on-chain `oracle`
ORACLE_PRIVATE_KEY=

# AI auditor (/api/verify, /api/judge)
OPENAI_API_KEY=
